{
  "name": "StackPilot Python + Vue",
  "settings": "{\n  \"editor.formatOnSave\": true,\n  \"python.analysis.autoImportCompletions\": true,\n  \"python.analysis.typeCheckingMode\": \"basic\",\n  \"[python]\": {\n    \"editor.defaultFormatter\": \"charliermarsh.ruff\"\n  },\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \"[typescript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \"[vue]\": {\n    \"editor.defaultFormatter\": \"Vue.volar\"\n  }\n}",
  "extensions": "[\n  { \"identifier\": { \"id\": \"ms-python.python\" }, \"displayName\": \"Python\" },\n  { \"identifier\": { \"id\": \"ms-python.vscode-pylance\" }, \"displayName\": \"Pylance\" },\n  { \"identifier\": { \"id\": \"ms-python.debugpy\" }, \"displayName\": \"Python Debugger\" },\n  { \"identifier\": { \"id\": \"charliermarsh.ruff\" }, \"displayName\": \"Ruff\" },\n  { \"identifier\": { \"id\": \"Vue.volar\" }, \"displayName\": \"Vue - Official\" },\n  { \"identifier\": { \"id\": \"dbaeumer.vscode-eslint\" }, \"displayName\": \"ESLint\" },\n  { \"identifier\": { \"id\": \"esbenp.prettier-vscode\" }, \"displayName\": \"Prettier\" }\n]"
